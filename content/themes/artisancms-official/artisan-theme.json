{
  "name": "ArtisanCMS Official",
  "slug": "artisancms-official",
  "version": "1.0.0",
  "style": "default",
  "description": "Theme officiel du site artisancms.dev — Gradient blue-violet moderne avec dark mode, hero anime et layouts optimises pour un site produit/SaaS.",
  "author": {
    "name": "ArtisanCMS",
    "url": "https://artisancms.dev"
  },
  "license": "MIT",
  "requires": {
    "cms": ">=1.0.0"
  },
  "preview": "assets/images/preview.png",
  "category": "business",
  "tags": [
    "official",
    "saas",
    "product",
    "gradient",
    "modern",
    "dark-mode",
    "landing"
  ],
  "layouts": [
    {
      "slug": "default",
      "name": "Par defaut",
      "regions": [
        "header",
        "content",
        "footer"
      ]
    },
    {
      "slug": "full-width",
      "name": "Pleine largeur",
      "regions": [
        "header",
        "content",
        "footer"
      ]
    },
    {
      "slug": "landing",
      "name": "Landing page",
      "regions": [
        "header",
        "content",
        "footer"
      ]
    },
    {
      "slug": "blog",
      "name": "Blog",
      "regions": [
        "header",
        "content",
        "sidebar",
        "footer"
      ]
    }
  ],
  "menu_locations": [
    {
      "slug": "header",
      "name": "Navigation principale"
    },
    {
      "slug": "footer",
      "name": "Navigation pied de page"
    }
  ],
  "customization": {
    "header": {
      "logo_url": {
        "label": "Logo",
        "type": "image",
        "default": ""
      },
      "height": {
        "label": "Hauteur du header",
        "type": "select",
        "default": "72px",
        "options": [
          "48px",
          "56px",
          "64px",
          "72px",
          "80px"
        ]
      },
      "style": {
        "label": "Style",
        "type": "select",
        "default": "transparent",
        "options": [
          "solid",
          "transparent",
          "gradient"
        ]
      },
      "sticky": {
        "label": "Header fixe",
        "type": "boolean",
        "default": true
      },
      "background_color": {
        "label": "Couleur de fond",
        "type": "color",
        "default": "#0f172a"
      },
      "text_color": {
        "label": "Couleur du texte",
        "type": "color",
        "default": "#f1f5f9"
      },
      "menu_alignment": {
        "label": "Alignement du menu",
        "type": "select",
        "default": "right",
        "options": [
          "left",
          "center",
          "right"
        ]
      },
      "variant": {
        "label": "Style du header",
        "type": "select",
        "default": "classic",
        "options": [
          "classic",
          "centered",
          "split",
          "stacked",
          "minimal"
        ]
      },
      "mobile_menu_style": {
        "label": "Menu mobile",
        "type": "select",
        "default": "hamburger",
        "options": [
          "hamburger",
          "slide",
          "fullscreen"
        ]
      },
      "cta_text": {
        "label": "Texte du bouton CTA",
        "type": "text",
        "default": "Star on GitHub"
      },
      "cta_url": {
        "label": "URL du bouton CTA",
        "type": "text",
        "default": "https://github.com/artisancms/artisancms"
      },
      "cta_style": {
        "label": "Style du CTA",
        "type": "select",
        "default": "outline",
        "options": [
          "primary",
          "secondary",
          "outline"
        ]
      }
    },
    "footer": {
      "layout": {
        "label": "Disposition du footer",
        "type": "select",
        "default": "columns",
        "options": [
          "simple",
          "columns",
          "minimal",
          "centered",
          "magazine"
        ]
      },
      "columns": {
        "label": "Nombre de colonnes",
        "type": "select",
        "default": "4",
        "options": [
          "2",
          "3",
          "4"
        ]
      },
      "background_color": {
        "label": "Couleur de fond",
        "type": "color",
        "default": "#0f172a"
      },
      "text_color": {
        "label": "Couleur du texte",
        "type": "color",
        "default": "#94a3b8"
      },
      "copyright_text": {
        "label": "Texte copyright",
        "type": "text",
        "default": "© {year} {site_name}. Tous droits reserves."
      },
      "show_social_links": {
        "label": "Afficher les liens sociaux",
        "type": "boolean",
        "default": true
      },
      "social_github": {
        "label": "GitHub URL",
        "type": "text",
        "default": "https://github.com/artisancms/artisancms"
      },
      "social_twitter": {
        "label": "Twitter / X URL",
        "type": "text",
        "default": ""
      },
      "social_discord": {
        "label": "Discord URL",
        "type": "text",
        "default": ""
      },
      "show_powered_by": {
        "label": "Afficher Propulse par ArtisanCMS",
        "type": "boolean",
        "default": true
      },
      "show_newsletter": {
        "label": "Afficher le formulaire newsletter",
        "type": "boolean",
        "default": true
      }
    },
    "colors": {
      "primary": {
        "label": "Couleur principale",
        "type": "color",
        "default": "#3b82f6"
      },
      "secondary": {
        "label": "Couleur secondaire",
        "type": "color",
        "default": "#64748b"
      },
      "accent": {
        "label": "Couleur accent",
        "type": "color",
        "default": "#8b5cf6"
      },
      "background": {
        "label": "Fond de page",
        "type": "color",
        "default": "#ffffff"
      },
      "surface": {
        "label": "Fond des cartes",
        "type": "color",
        "default": "#f8fafc"
      },
      "text": {
        "label": "Couleur du texte",
        "type": "color",
        "default": "#0f172a"
      },
      "text_muted": {
        "label": "Texte secondaire",
        "type": "color",
        "default": "#64748b"
      },
      "border": {
        "label": "Bordures",
        "type": "color",
        "default": "#e2e8f0"
      },
      "link": {
        "label": "Couleur des liens",
        "type": "color",
        "default": "#3b82f6"
      },
      "link_hover": {
        "label": "Liens au survol",
        "type": "color",
        "default": "#2563eb"
      },
      "success": {
        "label": "Succes",
        "type": "color",
        "default": "#22c55e"
      },
      "warning": {
        "label": "Avertissement",
        "type": "color",
        "default": "#f59e0b"
      },
      "error": {
        "label": "Erreur",
        "type": "color",
        "default": "#ef4444"
      }
    },
    "fonts": {
      "heading": {
        "label": "Police des titres",
        "type": "font",
        "default": "Inter"
      },
      "body": {
        "label": "Police du corps",
        "type": "font",
        "default": "Inter"
      },
      "base_size": {
        "label": "Taille de base",
        "type": "select",
        "default": "16px",
        "options": [
          "14px",
          "15px",
          "16px",
          "17px",
          "18px"
        ]
      },
      "h1_size": {
        "label": "Taille H1",
        "type": "text",
        "default": "3.5rem"
      },
      "h2_size": {
        "label": "Taille H2",
        "type": "text",
        "default": "2.25rem"
      },
      "h3_size": {
        "label": "Taille H3",
        "type": "text",
        "default": "1.5rem"
      },
      "h4_size": {
        "label": "Taille H4",
        "type": "text",
        "default": "1.25rem"
      },
      "h5_size": {
        "label": "Taille H5",
        "type": "text",
        "default": "1.125rem"
      },
      "h6_size": {
        "label": "Taille H6",
        "type": "text",
        "default": "1rem"
      },
      "heading_weight": {
        "label": "Graisse titres",
        "type": "select",
        "default": "700",
        "options": [
          "400",
          "500",
          "600",
          "700",
          "800"
        ]
      },
      "heading_italic": {
        "label": "Titres en italique",
        "type": "boolean",
        "default": false
      },
      "line_height": {
        "label": "Interligne",
        "type": "select",
        "default": "1.6",
        "options": [
          "1.4",
          "1.5",
          "1.6",
          "1.7",
          "1.8"
        ]
      },
      "letter_spacing": {
        "label": "Espacement lettres",
        "type": "select",
        "default": "0",
        "options": [
          "-0.025em",
          "0",
          "0.025em",
          "0.05em",
          "0.1em"
        ]
      }
    },
    "layout": {
      "container_width": {
        "label": "Largeur max",
        "type": "select",
        "default": "1280px",
        "options": [
          "1024px",
          "1280px",
          "1440px",
          "100%"
        ]
      },
      "border_radius": {
        "label": "Arrondi",
        "type": "select",
        "default": "0.75rem",
        "options": [
          "0",
          "0.25rem",
          "0.5rem",
          "0.625rem",
          "0.75rem",
          "1rem"
        ]
      },
      "section_spacing": {
        "label": "Espacement sections",
        "type": "select",
        "default": "large",
        "options": [
          "compact",
          "normal",
          "large",
          "xlarge"
        ]
      },
      "sidebar_position": {
        "label": "Position sidebar",
        "type": "select",
        "default": "right",
        "options": [
          "left",
          "right",
          "none"
        ]
      },
      "content_width": {
        "label": "Largeur contenu",
        "type": "select",
        "default": "65ch",
        "options": [
          "55ch",
          "60ch",
          "65ch",
          "70ch",
          "75ch",
          "100%"
        ]
      }
    },
    "global_styles": {
      "button_style": {
        "label": "Style des boutons",
        "type": "select",
        "default": "rounded",
        "options": [
          "square",
          "rounded",
          "pill"
        ]
      },
      "card_style": {
        "label": "Style des cartes",
        "type": "select",
        "default": "shadow",
        "options": [
          "flat",
          "shadow",
          "bordered"
        ]
      },
      "shadow_intensity": {
        "label": "Intensite des ombres",
        "type": "select",
        "default": "medium",
        "options": [
          "none",
          "light",
          "medium",
          "strong"
        ]
      },
      "enable_animations": {
        "label": "Activer les animations",
        "type": "boolean",
        "default": true
      }
    },
    "spacing": {
      "block_spacing": {
        "label": "Espacement entre blocs",
        "type": "select",
        "default": "normal",
        "options": [
          "compact",
          "normal",
          "relaxed",
          "spacious"
        ]
      }
    }
  },
  "font_imports": [
    "https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap",
    "https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap"
  ],
  "css_variables": {
    "--color-primary": "#3b82f6",
    "--color-primary-hover": "#2563eb",
    "--color-primary-light": "#dbeafe",
    "--color-secondary": "#64748b",
    "--color-accent": "#8b5cf6",
    "--color-accent-hover": "#7c3aed",
    "--color-background": "#ffffff",
    "--color-surface": "#f8fafc",
    "--color-text": "#0f172a",
    "--color-text-muted": "#64748b",
    "--color-border": "#e2e8f0",
    "--font-heading": "'Inter', system-ui, sans-serif",
    "--font-body": "'Inter', system-ui, sans-serif",
    "--font-mono": "'JetBrains Mono', 'Fira Code', monospace",
    "--font-size-base": "16px",
    "--border-radius": "0.75rem",
    "--container-width": "1280px",
    "--section-padding": "96px",
    "--gradient-hero": "linear-gradient(135deg, #3b82f6 0%, #8b5cf6 50%, #ec4899 100%)"
  },
  "supports": [
    "dark_mode",
    "responsive"
  ],
  "default_template": "artisancms-site"
}
