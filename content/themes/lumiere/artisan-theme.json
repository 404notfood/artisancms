{
  "name": "Lumière",
  "slug": "lumiere",
  "version": "1.0.0",
  "description": "Thème luxury blanc et or — élégance intemporelle pour hôtels, spas, boutiques premium et maisons de haute gamme. Typographie Cormorant Garamond + Jost.",
  "author": {
    "name": "ArtisanCMS",
    "url": "https://artisancms.dev"
  },
  "license": "MIT",
  "requires": { "cms": ">=1.0.0" },
  "preview": "assets/images/preview.png",
  "category": "luxury",
  "tags": ["luxury", "hotel", "spa", "boutique", "elegant", "gold", "white"],
  "layouts": [
    { "slug": "default", "name": "Par défaut", "regions": ["header", "content", "footer"] },
    { "slug": "full-width", "name": "Pleine largeur", "regions": ["header", "content", "footer"] },
    { "slug": "landing", "name": "Landing page", "regions": ["content"] },
    { "slug": "minimal", "name": "Minimal — sans navigation", "regions": ["content"] }
  ],
  "menu_locations": [
    { "slug": "header", "name": "Navigation principale" },
    { "slug": "footer", "name": "Navigation pied de page" },
    { "slug": "legal", "name": "Liens légaux (footer)" }
  ],
  "customization": {
    "header": {
      "logo_url": { "label": "Logo", "type": "image", "default": "" },
      "height": { "label": "Hauteur du header", "type": "select", "default": "80px", "options": ["64px", "72px", "80px", "96px", "112px"] },
      "style": { "label": "Style", "type": "select", "default": "solid", "options": ["solid", "transparent", "blur"] },
      "sticky": { "label": "Header fixe", "type": "boolean", "default": true },
      "background_color": { "label": "Couleur de fond", "type": "color", "default": "#ffffff" },
      "text_color": { "label": "Couleur du texte", "type": "color", "default": "#1c1917" },
      "accent_line": { "label": "Ligne accent dorée sous le header", "type": "boolean", "default": true },
      "menu_alignment": { "label": "Alignement du menu", "type": "select", "default": "center", "options": ["left", "center", "right"] },
      "mobile_menu_style": { "label": "Menu mobile", "type": "select", "default": "fullscreen", "options": ["hamburger", "slide", "fullscreen"] },
      "cta_text": { "label": "Texte du bouton CTA", "type": "text", "default": "Réserver" },
      "cta_url": { "label": "URL du bouton CTA", "type": "text", "default": "/reservation" },
      "cta_style": { "label": "Style du CTA", "type": "select", "default": "primary", "options": ["primary", "secondary", "outline"] }
    },
    "footer": {
      "layout": { "label": "Style du footer", "type": "select", "default": "columns", "options": ["simple", "columns", "minimal", "luxury"] },
      "columns": { "label": "Nombre de colonnes", "type": "select", "default": "3", "options": ["2", "3", "4"] },
      "background_color": { "label": "Couleur de fond", "type": "color", "default": "#1c1917" },
      "text_color": { "label": "Couleur du texte", "type": "color", "default": "#d6d3d1" },
      "accent_color": { "label": "Couleur accent titres", "type": "color", "default": "#d4af37" },
      "copyright_text": { "label": "Texte copyright", "type": "text", "default": "© {year} {site_name}. Tous droits réservés." },
      "tagline": { "label": "Signature / tagline", "type": "text", "default": "L'excellence à chaque détail." },
      "show_social_links": { "label": "Afficher les liens sociaux", "type": "boolean", "default": true },
      "social_facebook": { "label": "Facebook URL", "type": "text", "default": "" },
      "social_instagram": { "label": "Instagram URL", "type": "text", "default": "" },
      "social_linkedin": { "label": "LinkedIn URL", "type": "text", "default": "" },
      "show_powered_by": { "label": "Afficher Propulsé par ArtisanCMS", "type": "boolean", "default": true }
    },
    "colors": {
      "primary": { "label": "Couleur principale (or)", "type": "color", "default": "#d4af37" },
      "primary_light": { "label": "Or clair", "type": "color", "default": "#f5e6a3" },
      "primary_dark": { "label": "Or foncé", "type": "color", "default": "#a07b20" },
      "secondary": { "label": "Couleur secondaire (ivoire)", "type": "color", "default": "#faf9f7" },
      "accent": { "label": "Couleur accent (ivoire chaleureux)", "type": "color", "default": "#f5f0e8" },
      "background": { "label": "Fond de page", "type": "color", "default": "#ffffff" },
      "surface": { "label": "Fond des cartes / sections", "type": "color", "default": "#faf9f7" },
      "dark": { "label": "Couleur sombre (footer/héros)", "type": "color", "default": "#1c1917" },
      "text": { "label": "Couleur du texte principal", "type": "color", "default": "#1c1917" },
      "text_muted": { "label": "Texte secondaire", "type": "color", "default": "#78716c" },
      "link": { "label": "Couleur des liens", "type": "color", "default": "#a07b20" },
      "link_hover": { "label": "Liens au survol", "type": "color", "default": "#d4af37" },
      "border": { "label": "Couleur des bordures", "type": "color", "default": "#e7e5e4" },
      "success": { "label": "Succès", "type": "color", "default": "#22c55e" },
      "warning": { "label": "Avertissement", "type": "color", "default": "#f59e0b" },
      "error": { "label": "Erreur", "type": "color", "default": "#ef4444" }
    },
    "fonts": {
      "heading": { "label": "Police des titres", "type": "font", "default": "Cormorant Garamond" },
      "body": { "label": "Police du corps", "type": "font", "default": "Jost" },
      "accent": { "label": "Police accent (labels, captions)", "type": "font", "default": "Jost" },
      "base_size": { "label": "Taille de base", "type": "select", "default": "17px", "options": ["15px", "16px", "17px", "18px", "19px"] },
      "h1_size": { "label": "Taille H1", "type": "text", "default": "4rem" },
      "h2_size": { "label": "Taille H2", "type": "text", "default": "2.75rem" },
      "h3_size": { "label": "Taille H3", "type": "text", "default": "1.875rem" },
      "h4_size": { "label": "Taille H4", "type": "text", "default": "1.375rem" },
      "h5_size": { "label": "Taille H5", "type": "text", "default": "1.125rem" },
      "h6_size": { "label": "Taille H6", "type": "text", "default": "1rem" },
      "heading_weight": { "label": "Graisse titres", "type": "select", "default": "400", "options": ["300", "400", "500", "600", "700"] },
      "heading_italic": { "label": "Titres en italique", "type": "boolean", "default": false },
      "line_height": { "label": "Interligne", "type": "select", "default": "1.7", "options": ["1.5", "1.6", "1.7", "1.8", "1.9"] },
      "letter_spacing": { "label": "Espacement lettres", "type": "select", "default": "0", "options": ["-0.025em", "0", "0.025em", "0.05em"] }
    },
    "layout": {
      "container_width": { "label": "Largeur max", "type": "select", "default": "1200px", "options": ["960px", "1080px", "1200px", "1400px"] },
      "border_radius": { "label": "Arrondi boutons/cartes", "type": "select", "default": "0.25rem", "options": ["0", "0.125rem", "0.25rem", "0.5rem", "1rem"] },
      "section_spacing": { "label": "Espacement sections", "type": "select", "default": "large", "options": ["compact", "normal", "large", "xlarge"] },
      "sidebar_position": { "label": "Position sidebar", "type": "select", "default": "right", "options": ["left", "right", "none"] },
      "content_width": { "label": "Largeur contenu articles", "type": "select", "default": "70ch", "options": ["55ch", "60ch", "65ch", "70ch", "75ch"] }
    },
    "decorative": {
      "show_ornaments": { "label": "Ornements décoratifs dorés", "type": "boolean", "default": true },
      "divider_style": { "label": "Style des séparateurs", "type": "select", "default": "ornament", "options": ["none", "line", "dots", "ornament", "leaf"] },
      "hero_overlay_opacity": { "label": "Opacité overlay héros (%)", "type": "number", "default": 40, "min": 0, "max": 90 },
      "label_style": { "label": "Style des labels de section", "type": "select", "default": "uppercase-spaced", "options": ["none", "uppercase", "uppercase-spaced", "italic"] }
    },
    "global_styles": {
      "button_style": { "label": "Style des boutons", "type": "select", "default": "square", "options": ["square", "rounded", "pill"] },
      "card_style": { "label": "Style des cartes", "type": "select", "default": "bordered", "options": ["flat", "shadow", "bordered", "none"] },
      "shadow_intensity": { "label": "Intensité des ombres", "type": "select", "default": "light", "options": ["none", "light", "medium", "strong"] },
      "enable_animations": { "label": "Activer les animations", "type": "boolean", "default": true },
      "hover_lift": { "label": "Effet de survol (lift)", "type": "boolean", "default": true }
    }
  },
  "font_imports": [
    "https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&family=Jost:wght@300;400;500;600;700&display=swap"
  ],
  "css_variables": {
    "--color-primary": "#d4af37",
    "--color-primary-light": "#f5e6a3",
    "--color-primary-dark": "#a07b20",
    "--color-secondary": "#faf9f7",
    "--color-accent": "#f5f0e8",
    "--color-dark": "#1c1917",
    "--color-surface": "#faf9f7",
    "--color-text": "#1c1917",
    "--color-text-muted": "#78716c",
    "--color-border": "#e7e5e4",
    "--font-heading": "'Cormorant Garamond', Georgia, serif",
    "--font-body": "'Jost', system-ui, sans-serif",
    "--font-size-base": "17px",
    "--border-radius": "0.25rem",
    "--container-width": "1200px",
    "--section-padding": "96px"
  },
  "supports": ["dark_mode", "responsive", "rtl"]
}
