{
  "name": "Studio",
  "slug": "studio",
  "version": "1.0.0",
  "style": "creative",
  "description": "Thème studio créatif avec navigation sidebar fixe — fond charbon profond, accent violet électrique, pour portfolios de freelances, studios de design et agences créatives d'exception.",
  "author": {
    "name": "ArtisanCMS",
    "url": "https://artisancms.dev"
  },
  "license": "MIT",
  "requires": {
    "cms": ">=1.0.0"
  },
  "preview": "assets/images/preview.png",
  "category": "creative",
  "tags": ["dark", "sidebar", "studio", "portfolio", "creative", "freelance", "premium"],
  "layouts": [
    {
      "slug": "sidebar",
      "name": "Sidebar navigation",
      "regions": ["sidebar", "content"]
    },
    {
      "slug": "default",
      "name": "Par défaut (sidebar)",
      "regions": ["sidebar", "content"]
    },
    {
      "slug": "full",
      "name": "Pleine largeur",
      "regions": ["content"]
    }
  ],
  "menu_locations": [
    {
      "slug": "sidebar",
      "name": "Navigation sidebar"
    },
    {
      "slug": "footer",
      "name": "Liens bas de sidebar"
    }
  ],
  "customization": {
    "header": {
      "logo_url": {
        "label": "Logo",
        "type": "image",
        "default": ""
      },
      "height": {
        "label": "Hauteur du header",
        "type": "select",
        "default": "64px",
        "options": ["56px", "64px", "72px", "80px"]
      },
      "style": {
        "label": "Style",
        "type": "select",
        "default": "transparent",
        "options": ["solid", "transparent", "blur"]
      },
      "sticky": {
        "label": "Header fixe",
        "type": "boolean",
        "default": false
      },
      "background_color": {
        "label": "Couleur de fond",
        "type": "color",
        "default": "#0c0c0e"
      },
      "text_color": {
        "label": "Couleur du texte",
        "type": "color",
        "default": "#fafafa"
      },
      "menu_alignment": {
        "label": "Alignement du menu",
        "type": "select",
        "default": "right",
        "options": ["left", "center", "right"]
      },
      "variant": {
        "label": "Style du header",
        "type": "select",
        "default": "minimal",
        "options": ["classic", "centered", "split", "stacked", "minimal"]
      },
      "mobile_menu_style": {
        "label": "Menu mobile",
        "type": "select",
        "default": "slide",
        "options": ["hamburger", "slide", "fullscreen"]
      },
      "cta_text": {
        "label": "Texte du bouton CTA",
        "type": "text",
        "default": "Démarrer un projet"
      },
      "cta_url": {
        "label": "URL du bouton CTA",
        "type": "text",
        "default": "/contact"
      },
      "cta_style": {
        "label": "Style du CTA",
        "type": "select",
        "default": "primary",
        "options": ["primary", "outline", "glow"]
      }
    },
    "footer": {
      "layout": {
        "label": "Disposition du footer",
        "type": "select",
        "default": "minimal",
        "options": ["simple", "columns", "minimal", "centered", "magazine"]
      },
      "columns": {
        "label": "Nombre de colonnes",
        "type": "select",
        "default": "3",
        "options": ["2", "3", "4"]
      },
      "background_color": {
        "label": "Couleur de fond",
        "type": "color",
        "default": "#080808"
      },
      "text_color": {
        "label": "Couleur du texte",
        "type": "color",
        "default": "#71717a"
      },
      "accent_color": {
        "label": "Couleur accent",
        "type": "color",
        "default": "#7c3aed"
      },
      "copyright_text": {
        "label": "Texte copyright",
        "type": "text",
        "default": "© {year} {site_name}"
      },
      "show_social_links": {
        "label": "Afficher les liens sociaux",
        "type": "boolean",
        "default": true
      },
      "social_twitter": { "label": "Twitter / X URL", "type": "text", "default": "" },
      "social_instagram": { "label": "Instagram URL", "type": "text", "default": "" },
      "social_linkedin": { "label": "LinkedIn URL", "type": "text", "default": "" },
      "social_github": { "label": "GitHub URL", "type": "text", "default": "" },
      "social_dribbble": { "label": "Dribbble URL", "type": "text", "default": "" },
      "show_powered_by": {
        "label": "Afficher Propulsé par ArtisanCMS",
        "type": "boolean",
        "default": true
      }
    },
    "sidebar": {
      "width": {
        "label": "Largeur sidebar",
        "type": "select",
        "default": "260px",
        "options": ["220px", "260px", "300px", "320px"]
      },
      "background_color": {
        "label": "Fond sidebar",
        "type": "color",
        "default": "#080808"
      },
      "text_color": {
        "label": "Texte navigation",
        "type": "color",
        "default": "#a1a1aa"
      },
      "active_color": {
        "label": "Lien actif",
        "type": "color",
        "default": "#ffffff"
      },
      "logo_url": {
        "label": "Logo",
        "type": "image",
        "default": ""
      },
      "show_tagline": {
        "label": "Afficher le tagline",
        "type": "boolean",
        "default": true
      },
      "tagline": {
        "label": "Tagline sous le logo",
        "type": "text",
        "default": "Studio créatif"
      },
      "cta_text": {
        "label": "Texte du bouton CTA",
        "type": "text",
        "default": "Démarrer un projet"
      },
      "cta_url": {
        "label": "URL du CTA",
        "type": "text",
        "default": "/contact"
      },
      "show_social": {
        "label": "Afficher les réseaux sociaux",
        "type": "boolean",
        "default": true
      },
      "social_twitter": { "label": "Twitter/X", "type": "text", "default": "" },
      "social_instagram": { "label": "Instagram", "type": "text", "default": "" },
      "social_linkedin": { "label": "LinkedIn", "type": "text", "default": "" },
      "social_github": { "label": "GitHub", "type": "text", "default": "" },
      "social_dribbble": { "label": "Dribbble", "type": "text", "default": "" },
      "border_color": {
        "label": "Bordure séparatrice",
        "type": "color",
        "default": "rgba(255,255,255,0.06)"
      }
    },
    "colors": {
      "primary": {
        "label": "Couleur principale",
        "type": "color",
        "default": "#7c3aed"
      },
      "primary_light": {
        "label": "Variante claire",
        "type": "color",
        "default": "#a78bfa"
      },
      "accent": {
        "label": "Accent secondaire",
        "type": "color",
        "default": "#06b6d4"
      },
      "background": {
        "label": "Fond principal",
        "type": "color",
        "default": "#0c0c0e"
      },
      "surface": {
        "label": "Fond des cartes",
        "type": "color",
        "default": "#141416"
      },
      "text": {
        "label": "Texte principal",
        "type": "color",
        "default": "#fafafa"
      },
      "text_muted": {
        "label": "Texte secondaire",
        "type": "color",
        "default": "#71717a"
      },
      "border": {
        "label": "Bordures",
        "type": "color",
        "default": "rgba(255,255,255,0.07)"
      },
      "link": {
        "label": "Couleur des liens",
        "type": "color",
        "default": "#a78bfa"
      },
      "link_hover": {
        "label": "Liens au survol",
        "type": "color",
        "default": "#c4b5fd"
      },
      "success": {
        "label": "Succès",
        "type": "color",
        "default": "#22c55e"
      },
      "warning": {
        "label": "Avertissement",
        "type": "color",
        "default": "#f59e0b"
      },
      "error": {
        "label": "Erreur",
        "type": "color",
        "default": "#ef4444"
      }
    },
    "fonts": {
      "heading": {
        "label": "Police des titres",
        "type": "font",
        "default": "Syne"
      },
      "body": {
        "label": "Police du corps",
        "type": "font",
        "default": "Inter"
      },
      "base_size": {
        "label": "Taille de base",
        "type": "select",
        "default": "15px",
        "options": ["14px", "15px", "16px", "17px"]
      },
      "h1_size": {
        "label": "Taille H1",
        "type": "text",
        "default": "3rem"
      },
      "h2_size": {
        "label": "Taille H2",
        "type": "text",
        "default": "2.25rem"
      },
      "h3_size": {
        "label": "Taille H3",
        "type": "text",
        "default": "1.625rem"
      },
      "h4_size": {
        "label": "Taille H4",
        "type": "text",
        "default": "1.25rem"
      },
      "h5_size": {
        "label": "Taille H5",
        "type": "text",
        "default": "1.125rem"
      },
      "h6_size": {
        "label": "Taille H6",
        "type": "text",
        "default": "1rem"
      },
      "heading_weight": {
        "label": "Graisse titres",
        "type": "select",
        "default": "700",
        "options": ["500", "600", "700", "800"]
      },
      "line_height": {
        "label": "Interligne",
        "type": "select",
        "default": "1.7",
        "options": ["1.5", "1.6", "1.7", "1.8"]
      },
      "letter_spacing": {
        "label": "Espacement lettres",
        "type": "select",
        "default": "-0.01em",
        "options": ["-0.03em", "-0.01em", "0", "0.025em"]
      }
    },
    "layout": {
      "container_width": {
        "label": "Largeur max contenu",
        "type": "select",
        "default": "900px",
        "options": ["720px", "800px", "900px", "1080px", "100%"]
      },
      "border_radius": {
        "label": "Arrondi",
        "type": "select",
        "default": "0.5rem",
        "options": ["0", "0.25rem", "0.5rem", "0.75rem", "1rem"]
      },
      "section_spacing": {
        "label": "Espacement sections",
        "type": "select",
        "default": "large",
        "options": ["compact", "normal", "large", "xlarge"]
      },
      "sidebar_position": {
        "label": "Position sidebar",
        "type": "select",
        "default": "none",
        "options": ["left", "right", "none"]
      },
      "content_width": {
        "label": "Largeur contenu texte",
        "type": "select",
        "default": "65ch",
        "options": ["55ch", "60ch", "65ch", "70ch", "100%"]
      }
    },
    "global_styles": {
      "button_style": {
        "label": "Style des boutons",
        "type": "select",
        "default": "rounded",
        "options": ["square", "rounded", "pill"]
      },
      "card_style": {
        "label": "Style des cartes",
        "type": "select",
        "default": "bordered-dark",
        "options": ["flat", "shadow", "bordered-dark", "glass"]
      },
      "shadow_intensity": {
        "label": "Intensité des ombres",
        "type": "select",
        "default": "medium",
        "options": ["none", "light", "medium", "strong"]
      },
      "enable_animations": {
        "label": "Activer les animations",
        "type": "boolean",
        "default": true
      }
    }
  },
  "css_variables": {
    "--color-primary": "#7c3aed",
    "--color-primary-light": "#a78bfa",
    "--color-accent": "#06b6d4",
    "--color-background": "#0c0c0e",
    "--color-surface": "#141416",
    "--color-text": "#fafafa",
    "--color-text-muted": "#71717a",
    "--color-border": "rgba(255,255,255,0.07)",
    "--font-heading": "'Syne', system-ui, sans-serif",
    "--font-body": "'Inter', system-ui, sans-serif",
    "--font-size-base": "15px",
    "--border-radius": "0.5rem",
    "--container-width": "900px",
    "--sidebar-width": "260px",
    "--section-padding": "80px"
  },
  "font_imports": [
    "https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=Inter:wght@300;400;500;600&display=swap"
  ],
  "supports": ["dark_mode", "responsive", "sidebar"],
  "default_template": "studio-portfolio"
}
