{
  "name": "Default Theme",
  "slug": "default",
  "version": "1.0.0",
  "style": "default",
  "description": "Thème par défaut d'ArtisanCMS — Moderne et responsive, idéal pour tout type de site.",
  "author": {
    "name": "ArtisanCMS",
    "url": "https://artisancms.dev"
  },
  "license": "MIT",
  "requires": { "cms": ">=1.0.0" },
  "preview": "assets/images/preview.png",
  "category": "general",
  "tags": ["default", "modern", "responsive", "clean", "minimal", "multipurpose"],
  "layouts": [
    { "slug": "default", "name": "Par défaut", "regions": ["header", "content", "footer"] },
    { "slug": "full-width", "name": "Pleine largeur", "regions": ["header", "content", "footer"] },
    { "slug": "landing", "name": "Landing page", "regions": ["content"] }
  ],
  "menu_locations": [
    { "slug": "header", "name": "Navigation principale" },
    { "slug": "footer", "name": "Navigation pied de page" }
  ],
  "customization": {
    "header": {
      "logo_url": { "label": "Logo", "type": "image", "default": "" },
      "height": { "label": "Hauteur du header", "type": "select", "default": "64px", "options": ["48px", "56px", "64px", "72px", "80px"] },
      "style": { "label": "Style", "type": "select", "default": "solid", "options": ["solid", "transparent", "gradient"] },
      "sticky": { "label": "Header fixe", "type": "boolean", "default": true },
      "background_color": { "label": "Couleur de fond", "type": "color", "default": "#ffffff" },
      "text_color": { "label": "Couleur du texte", "type": "color", "default": "#0f172a" },
      "menu_alignment": { "label": "Alignement du menu", "type": "select", "default": "right", "options": ["left", "center", "right"] },
      "variant": { "label": "Style du header", "type": "select", "default": "classic", "options": ["classic", "centered", "split", "stacked", "minimal"] },
      "mobile_menu_style": { "label": "Menu mobile", "type": "select", "default": "hamburger", "options": ["hamburger", "slide", "fullscreen"] },
      "cta_text": { "label": "Texte du bouton CTA", "type": "text", "default": "" },
      "cta_url": { "label": "URL du bouton CTA", "type": "text", "default": "" },
      "cta_style": { "label": "Style du CTA", "type": "select", "default": "primary", "options": ["primary", "secondary", "outline"] }
    },
    "footer": {
      "layout": { "label": "Disposition du footer", "type": "select", "default": "simple", "options": ["simple", "columns", "minimal", "centered", "magazine"] },
      "columns": { "label": "Nombre de colonnes", "type": "select", "default": "3", "options": ["2", "3", "4"] },
      "background_color": { "label": "Couleur de fond", "type": "color", "default": "#f8fafc" },
      "text_color": { "label": "Couleur du texte", "type": "color", "default": "#64748b" },
      "copyright_text": { "label": "Texte copyright", "type": "text", "default": "\u00a9 {year} {site_name}. Tous droits réservés." },
      "show_social_links": { "label": "Afficher les liens sociaux", "type": "boolean", "default": false },
      "social_facebook": { "label": "Facebook URL", "type": "text", "default": "" },
      "social_twitter": { "label": "Twitter / X URL", "type": "text", "default": "" },
      "social_instagram": { "label": "Instagram URL", "type": "text", "default": "" },
      "social_linkedin": { "label": "LinkedIn URL", "type": "text", "default": "" },
      "social_youtube": { "label": "YouTube URL", "type": "text", "default": "" },
      "show_powered_by": { "label": "Afficher Propulsé par ArtisanCMS", "type": "boolean", "default": true }
    },
    "colors": {
      "primary": { "label": "Couleur principale", "type": "color", "default": "#4f46e5" },
      "secondary": { "label": "Couleur secondaire", "type": "color", "default": "#64748b" },
      "accent": { "label": "Couleur accent", "type": "color", "default": "#f97316" },
      "background": { "label": "Fond de page", "type": "color", "default": "#ffffff" },
      "surface": { "label": "Fond des cartes", "type": "color", "default": "#f8fafc" },
      "text": { "label": "Couleur du texte", "type": "color", "default": "#0f172a" },
      "text_muted": { "label": "Texte secondaire", "type": "color", "default": "#64748b" },
      "border": { "label": "Bordures", "type": "color", "default": "#e2e8f0" },
      "link": { "label": "Couleur des liens", "type": "color", "default": "#4f46e5" },
      "link_hover": { "label": "Liens au survol", "type": "color", "default": "#4338ca" },
      "success": { "label": "Succès", "type": "color", "default": "#22c55e" },
      "warning": { "label": "Avertissement", "type": "color", "default": "#f59e0b" },
      "error": { "label": "Erreur", "type": "color", "default": "#ef4444" }
    },
    "fonts": {
      "heading": { "label": "Police des titres", "type": "font", "default": "Inter" },
      "body": { "label": "Police du corps", "type": "font", "default": "Inter" },
      "base_size": { "label": "Taille de base", "type": "select", "default": "16px", "options": ["14px", "15px", "16px", "17px", "18px"] },
      "h1_size": { "label": "Taille H1", "type": "text", "default": "2.75rem" },
      "h2_size": { "label": "Taille H2", "type": "text", "default": "2rem" },
      "h3_size": { "label": "Taille H3", "type": "text", "default": "1.5rem" },
      "h4_size": { "label": "Taille H4", "type": "text", "default": "1.25rem" },
      "h5_size": { "label": "Taille H5", "type": "text", "default": "1.125rem" },
      "h6_size": { "label": "Taille H6", "type": "text", "default": "1rem" },
      "heading_weight": { "label": "Graisse titres", "type": "select", "default": "600", "options": ["400", "500", "600", "700", "800"] },
      "heading_italic": { "label": "Titres en italique", "type": "boolean", "default": false },
      "line_height": { "label": "Interligne", "type": "select", "default": "1.6", "options": ["1.4", "1.5", "1.6", "1.7", "1.8"] },
      "letter_spacing": { "label": "Espacement lettres", "type": "select", "default": "0", "options": ["-0.025em", "0", "0.025em", "0.05em", "0.1em"] }
    },
    "layout": {
      "container_width": { "label": "Largeur max", "type": "select", "default": "1280px", "options": ["1024px", "1280px", "1440px", "100%"] },
      "border_radius": { "label": "Arrondi", "type": "select", "default": "0.625rem", "options": ["0", "0.25rem", "0.5rem", "0.625rem", "0.75rem", "1rem"] },
      "section_spacing": { "label": "Espacement sections", "type": "select", "default": "normal", "options": ["compact", "normal", "large", "xlarge"] },
      "sidebar_position": { "label": "Position sidebar", "type": "select", "default": "right", "options": ["left", "right", "none"] },
      "content_width": { "label": "Largeur contenu", "type": "select", "default": "65ch", "options": ["55ch", "60ch", "65ch", "70ch", "75ch", "100%"] }
    },
    "ecommerce": {
      "product_card_style": { "label": "Style carte produit", "type": "select", "default": "card", "options": ["card", "minimal", "overlay"] },
      "products_per_row": { "label": "Produits par ligne", "type": "select", "default": "3", "options": ["2", "3", "4"] },
      "image_aspect_ratio": { "label": "Ratio images", "type": "select", "default": "4/3", "options": ["1/1", "4/3", "3/2", "16/9"] },
      "show_quick_view": { "label": "Vue rapide", "type": "boolean", "default": true },
      "show_add_to_cart": { "label": "Bouton ajouter au panier", "type": "boolean", "default": true },
      "price_display": { "label": "Affichage du prix", "type": "select", "default": "inline", "options": ["inline", "below", "hidden"] },
      "sale_badge_style": { "label": "Style badge promo", "type": "select", "default": "ribbon", "options": ["ribbon", "circle", "tag"] }
    },
    "global_styles": {
      "button_style": { "label": "Style des boutons", "type": "select", "default": "rounded", "options": ["square", "rounded", "pill"] },
      "card_style": { "label": "Style des cartes", "type": "select", "default": "shadow", "options": ["flat", "shadow", "bordered"] },
      "shadow_intensity": { "label": "Intensité des ombres", "type": "select", "default": "medium", "options": ["none", "light", "medium", "strong"] },
      "enable_animations": { "label": "Activer les animations", "type": "boolean", "default": true }
    }
  },
  "font_imports": [
    "https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&display=swap"
  ],
  "css_variables": {
    "--color-primary": "#4f46e5",
    "--color-primary-hover": "#4338ca",
    "--color-primary-light": "#eef2ff",
    "--color-secondary": "#64748b",
    "--color-accent": "#f97316",
    "--color-background": "#ffffff",
    "--color-surface": "#f8fafc",
    "--color-text": "#0f172a",
    "--color-text-muted": "#64748b",
    "--color-border": "#e2e8f0",
    "--font-heading": "'Inter', system-ui, sans-serif",
    "--font-body": "'Inter', system-ui, sans-serif",
    "--font-size-base": "16px",
    "--border-radius": "0.625rem",
    "--container-width": "1280px",
    "--section-padding": "80px"
  },
  "supports": ["dark_mode", "responsive"],
  "default_template": "default"
}
