                                        "type": "text",
                                        "id": "pf-svc-s2",
                                        "props": { "content": "<h3 style='color:#7c3aed;margin-bottom:12px'>Developpement Frontend</h3><p style='color:#64748b;margin-bottom:12px'>Integration pixel-perfect de vos maquettes avec les technologies les plus modernes. Code propre, performant et accessible.</p><p style='color:#94a3b8;font-size:0.875rem'>A partir de 3 000 &euro;</p>" }
