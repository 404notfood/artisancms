                            },
                            {
                                "type": "spacer",
                                "id": "pf-about-sp2",
                                "props": { "height": 24 }
                            },
                            {
                                "type": "text",
                                "id": "pf-about-exp-text",
                                "props": { "content": "<p style='color:#475569;margin-bottom:20px'><strong style='color:#1e293b'>Freelance — Designer & Developpeur</strong><br/><span style='color:#7c3aed'>2021 - Aujourd'hui</span><br/>Projets web et mobile pour startups, PME et grands comptes. Plus de 40 projets livres.</p><p style='color:#475569;margin-bottom:20px'><strong style='color:#1e293b'>Agence Digitale Pixelcraft — Lead Designer</strong><br/><span style='color:#7c3aed'>2018 - 2021</span><br/>Direction artistique, management d'equipe design (4 personnes), mise en place du design system.</p><p style='color:#475569'><strong style='color:#1e293b'>Studio Web Neon — Designer & Integrateur</strong><br/><span style='color:#7c3aed'>2016 - 2018</span><br/>Design d'interfaces, integration frontend et collaboration avec les equipes back-end.</p>" }
