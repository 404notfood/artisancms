                                "type": "spacer",
                                "id": "blog-about-sp2",
                                "props": { "height": 32 }
                            },
                            {
                                "type": "grid",
                                "id": "blog-about-skills-grid",
                                "props": { "columns": 3, "gap": 32 },
                                "children": [
                                    {
                                        "type": "text",
                                        "id": "blog-about-sk1",
                                        "props": { "content": "<h3 style='color:#059669;text-align:center;margin-bottom:12px'>Frontend</h3><p style='color:#64748b;text-align:center'>React, TypeScript, Next.js, Tailwind CSS, tests unitaires et d'integration.</p>" }
                                    },
                                    {
                                        "type": "text",
                                        "id": "blog-about-sk2",
                                        "props": { "content": "<h3 style='color:#059669;text-align:center;margin-bottom:12px'>Backend</h3><p style='color:#64748b;text-align:center'>Laravel, Node.js, API REST et GraphQL, bases de donnees, architecture logicielle.</p>" }
                                    },
                                    {
                                        "type": "text",
                                        "id": "blog-about-sk3",
                                        "props": { "content": "<h3 style='color:#059669;text-align:center;margin-bottom:12px'>DevOps & Outils</h3><p style='color:#64748b;text-align:center'>Docker, CI/CD, monitoring, performance web, outils de productivite.</p>" }
                                    }
                                ]
                            }
                        ]
                    }
                ]
            }
        },
        {
