                                        "props": { "content": "<h3 style='color:#059669;text-align:center;margin-bottom:8px'>Design</h3><p style='color:#64748b;text-align:center'>UX/UI, design systems, Figma, accessibilite et tendances visuelles.</p>" }
                                    },
                                    {
                                        "type": "text",
                                        "id": "blog-home-cat3",
