        {
            "id": "about",
            "title": "A propos",
            "slug": "a-propos",
            "template": "default",
            "meta_title": "A propos - Mon Blog",
            "meta_description": "En savoir plus sur l'auteur et la mission de ce blog.",
            "content": {
                "blocks": [
                    {
                        "type": "hero",
                        "id": "blog-about-hero",
                        "props": {
                            "title": "A propos",
