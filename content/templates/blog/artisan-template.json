                                        "props": { "content": "<h3 style='color:#059669;text-align:center;margin-bottom:8px'>Developpement</h3><p style='color:#64748b;text-align:center'>React, Laravel, TypeScript, Node.js et les meilleures pratiques de code.</p>" }
