                                        "id": "blog-contact-details",
                                        "props": { "content": "<h2 style='color:#1e293b;margin-bottom:24px'>Coordonnees</h2><p style='color:#475569;margin-bottom:16px'><strong>Email</strong><br/>contact@mon-blog.fr</p><p style='color:#475569;margin-bottom:16px'><strong>Reseaux sociaux</strong><br/>Twitter : @monblog<br/>GitHub : github.com/monblog<br/>LinkedIn : linkedin.com/in/monblog</p><p style='color:#475569'><strong>Temps de reponse</strong><br/>Je reponds generalement sous 48 heures.</p>" }
                                    },
                                    {
                                        "type": "text",
                                        "id": "blog-contact-collab",
                                        "props": { "content": "<h2 style='color:#1e293b;margin-bottom:24px'>Collaborations</h2><p style='color:#475569;margin-bottom:16px'>Je suis ouvert aux propositions de :</p><ul style='color:#475569'><li style='margin-bottom:8px'><strong>Articles invites</strong> — Vous souhaitez publier sur ce blog ? Proposez-moi votre sujet.</li><li style='margin-bottom:8px'><strong>Relecture technique</strong> — Je peux relire vos articles techniques avant publication.</li><li style='margin-bottom:8px'><strong>Conferences et meetups</strong> — Disponible pour des talks sur le dev web.</li><li><strong>Consulting</strong> — Missions freelance en developpement web.</li></ul>" }
                                    }
                                ]
                            }
                        ]
                    }
                ]
            }
