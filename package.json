{
    "$schema": "https://www.schemastore.org/package.json",
    "private": true,
    "type": "module",
    "packageManager": "npm@11.6.0",
    "workspaces": [
        "packages/*"
    ],
    "scripts": {
        "build": "turbo run build && vite build",
        "dev": "concurrently \"vite\" \"turbo run dev --filter=./packages/*\"",
        "dev:app": "vite",
        "build:app": "tsc && vite build",
        "test": "turbo run test",
        "lint": "turbo run lint"
    },
    "devDependencies": {
        "@headlessui/react": "^2.0.0",
        "@inertiajs/react": "^2.0.0",
        "@tailwindcss/forms": "^0.5.3",
        "@tailwindcss/vite": "^4.0.0",
        "@types/node": "^22.12.0",
        "@types/react": "^19.0.0",
        "@types/react-dom": "^19.0.0",
        "@vitejs/plugin-react": "^4.2.0",
        "autoprefixer": "^10.4.12",
        "axios": "^1.11.0",
        "concurrently": "^9.0.1",
        "laravel-vite-plugin": "^2.0.0",
        "postcss": "^8.4.31",
        "react": "^19.0.0",
        "react-dom": "^19.0.0",
        "tailwindcss": "^4.0.0",
        "typescript": "^5.0.2",
        "vite": "^7.0.7"
    },
    "dependencies": {
        "@dnd-kit/core": "^6.3.1",
        "@dnd-kit/sortable": "^10.0.0",
        "@dnd-kit/utilities": "^3.2.2",
        "@tiptap/extension-color": "^3.20.2",
        "@tiptap/extension-link": "^3.20.2",
        "@tiptap/extension-placeholder": "^3.20.2",
        "@tiptap/extension-text-align": "^3.20.2",
        "@tiptap/extension-text-style": "^3.20.2",
        "@tiptap/extension-underline": "^3.20.2",
        "@tiptap/react": "^3.20.2",
        "@tiptap/starter-kit": "^3.20.2",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "immer": "^11.1.4",
        "lucide-react": "^0.577.0",
        "nanoid": "^5.1.6",
        "tailwind-merge": "^3.5.0",
        "zod": "^4.3.6",
        "zustand": "^5.0.11"
    },
    "devDependencies_note": "turbo added for monorepo orchestration",
    "optionalDependencies": {
        "turbo": "^2.5.0"
    }
}
